# PostgreSQL connection string
# Examples:
#   Local:   postgresql://postgres:password@localhost:5432/bravo4
#   Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/bravo4?sslmode=require
#   Railway: postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
DATABASE_URL="postgresql://postgres:password@localhost:5432/bravo4"

# NextAuth secret – generate with: npx auth secret
AUTH_SECRET=""

# App URL (used by NextAuth for callbacks)
# In production set this to your Vercel URL, e.g. https://bravo4.vercel.app
NEXTAUTH_URL="http://localhost:3000"
